# 当前项目的访问口令，作为 URL 第一段使用。
ACCESS_TOKEN=replace-with-a-long-random-token

# 允许访问的 Sub2API 账号 ID，多个 ID 使用英文逗号分隔。
ACCOUNT_IDS=1,2

# Sub2API 站点根地址；也可以直接填写以 /api/v1 结尾的地址。
SUB2API_URL=https://sub2api.example.com

# Sub2API 管理员账号密码。程序会自动登录并通过 refresh_token 续期。
SUB2API_ADMIN_EMAIL=admin@example.com
SUB2API_ADMIN_PASSWORD=replace-with-admin-password

# 可选兼容模式：管理员启用了 TOTP 2FA 或登录 Turnstile 时，改用 access_token。
# 设置账号密码时会优先使用账号密码模式。
# SUB2API_AUTH_TOKEN=replace-with-sub2api-admin-access-token

# true 时允许点击并执行重置；false 时前后端都会禁用重置。
ALLOW_RESET=false

# 可选：宿主机映射端口，仅供 docker-compose.yml 使用。
HOST_PORT=8080
