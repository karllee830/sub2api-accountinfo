# Sub2API 站点根地址；也可以直接填写以 /api/v1 结尾的地址。
SUB2API_URL=https://sub2api.example.com

# Sub2API 后台“设置 → 安全”中生成的 Admin API Key。
SUB2API_ADMIN_API_KEY=admin-replace-with-generated-key

# true 时允许用户对其订阅分组中的 OpenAI 账号执行重置。
ALLOW_RESET=false

# 反代部署时读取 X-Real-IP / X-Forwarded-For，用于转发 Sub2API Token 的会话绑定指纹。
# 开启后请勿将容器端口直接暴露给不可信网络。
TRUST_PROXY_HEADERS=true

# 可选：允许嵌入本页面的 CSP frame-ancestors 来源列表。
# 留空时自动使用 SUB2API_URL 的 origin。
# FRAME_ANCESTORS=https://sub2api.example.com

# 可选：宿主机映射端口，仅供 docker-compose.yml 使用。
HOST_PORT=8080
